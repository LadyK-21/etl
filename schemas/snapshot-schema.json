{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "comment": "A license must live under `origin.license`, not as a top-level `meta.license` (nor the legacy `meta.license_name` / `meta.license_url`, which SnapshotMeta.load_from_yaml also funnels into the top-level license). Those are deprecated SnapshotMeta-level fields that do not travel with the origin. Enforce this by forbidding `origin` together with any top-level license field (legacy `source:`-based snapshots have no `origin`, so they keep their own license location).",
      "not": {
        "anyOf": [
          {
            "required": [
              "origin",
              "license"
            ]
          },
          {
            "required": [
              "origin",
              "license_name"
            ]
          },
          {
            "required": [
              "origin",
              "license_url"
            ]
          }
        ]
      },
      "properties": {
        "name": {
          "type": "string"
        },
        "source_name": {
          "type": "string"
        },
        "publication_year": {
          "type": "integer"
        },
        "publication_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "url": {
          "type": "string"
        },
        "source_data_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_published_by": {
          "type": "string"
        },
        "license_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "license_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "date_accessed": {
          "type": "string",
          "format": "date"
        },
        "description": {
          "type": "string"
        },
        "access_notes": {
          "type": "string"
        },
        "is_public": {
          "type": "boolean"
        },
        "origin": {
          "$ref": "definitions.json#/origin"
        },
        "license": {
          "$ref": "definitions.json#/license"
        }
      }
    },
    "wdir": {
      "type": "string"
    },
    "autoupdate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the autoupdate. Snapshots that should belong to the same autoupdate should have the same name."
        },
        "frequency": {
          "type": "string",
          "description": "Frequency of the autoupdate. Can be 'daily', 'weekly', 'monthly', or 'yearly'."
        },
        "notify": {
          "type": "string",
          "description": "Slack user to notify when the autoupdate is successful."
        }
      },
      "required": [
        "name"
      ]
    },
    "outs": {
      "type": "array",
      "items": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "md5": {
              "type": "string"
            },
            "size": {
              "type": "integer"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "md5",
            "size",
            "path"
          ]
        }
      ]
    }
  },
  "required": [
    "meta"
  ]
}
